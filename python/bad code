def calculate_average(numbers):
    total = 0
    for num in numbers
        total += num
    average = total / len(numbers)
    return average

class DataProcessor:
    def __init__(self, name):
        self.name = name
        self.data = []
    
    def add_data(self, value)
        self.data.append(value)
    
    def process(self):
        result = []
        for i in range(len(self.data)):
            if self.data[i] > 10
                result.append(self.data[i] * 2)
        return result

