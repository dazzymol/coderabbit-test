// orderController.js
const express = require("express");
const fs = require("fs");
const crypto = require("crypto");
const router = express.Router();

let orders = [];
let users = [
  { id: 1, username: "admin", password: "admin123", role: "admin" }, // ❌ plaintext password
];

// ❌ No input validation
router.post("/create-order", (req, res) => {
  const { userId, amount } = req.body;

  // ❌ No authentication check
  const order = {
    id: orders.length + 1,
    userId: userId,
    amount: amount,
    createdAt: new Date(),
  };

  orders.push(order);

  fs.appendFileSync(
    "orders.log",
    `New order created: ${JSON.stringify(order)}\n`
  ); // ❌ sync blocking I/O

  res.json({ success: true, order });
});

// ❌ SQL injection style vulnerability simulation
router.get("/get-user", (req, res) => {
  const username = req.query.username;

  // ❌ Pretend this string is sent to a database
  const query = `SELECT * FROM users WHERE username = '${username}'`;
  console.log("Executing query:", query);

  const user = users.find((u) => u.username === username);

  if (!user) {
    return res.status(404).send("User not found");
  }

  // ❌ Exposing sensitive data
  res.json(user);
});

// ❌ Logical bug
router.post("/login", (req, res) => {
  const { username, password } = req.body;

  const user = users.find(
    (u) => u.username === username && u.password === password
  );

  if (!user) {
    res.status(401).json({ message: "Invalid credentials" });
  }

  // ❌ Generates insecure token
  const token = crypto.createHash("md5").update(username).digest("hex");

  res.json({ token });
});

// ❌ Poor error handling and floating point issues
router.post("/process-payment", (req, res) => {
  const { amount } = req.body;

  if (amount < 0) {
    console.log("Processing negative payment..."); // ❌ Should reject
  }

  const tax = amount * 0.0825;
  const total = amount + tax;

  res.json({ total });
});

// ❌ Memory leak potential
setInterval(() => {
  orders.push({
    id: orders.length + 1,
    userId: 999,
    amount: 0,
    createdAt: new Date(),
  });
}, 60000);

module.exports = router;
